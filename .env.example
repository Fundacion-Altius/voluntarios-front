NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_IMAGE_PREFIX=/
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production
AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
AZURE_AD_TENANT_ID=your-azure-ad-tenant-id
NEXT_PUBLIC_AZURE_AD_ENABLED=true

# Environment-specific variables
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_IS_PRODUCTION=false
NEXT_PUBLIC_IS_STAGING=false
NEXT_PUBLIC_IS_DEVELOPMENT=true

# Feature flags
NEXT_PUBLIC_FEATURE_NEW_CONTRACT_FLOW=false
NEXT_PUBLIC_FEATURE_ADVANCED_ANALYTICS=false
NEXT_PUBLIC_FEATURE_AZURE_AD_AUTH=true

# Vercel-specific variables (set in Vercel Dashboard)
# VERCEL_ENV is automatically set by Vercel (production/preview/development)
# VERCEL_URL is automatically set by Vercel (e.g., my-app.vercel.app)
